    <title>离别时刻</title>
    <link href="https://physics-lee.github.io/2025/04/02/Leave_USTC/"/>
    <id>https://physics-lee.github.io/2025/04/02/Leave_USTC/</id>
    <published>2025-04-01T16:00:00.000Z</published>
